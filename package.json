{
  "name": "desktop-pet",
  "version": "1.0.0",
  "description": "A tiny desktop pet that walks along the bottom of your screen",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac"
  },
  "build": {
    "appId": "com.desktoppet.blobfish",
    "productName": "水滴魚",
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html"
    ],
    "mac": {
      "category": "public.app-category.entertainment",
      "target": [
        "dir",
        "zip"
      ],
      "identity": null
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
