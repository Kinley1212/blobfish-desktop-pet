{
  "category": "idle",
  "phrases": [
    { "id": "grass-idle-01", "event": "idle.chatter", "text": "风没来。我先站着。", "weight": 5 },
    { "id": "grass-idle-02", "event": "idle.chatter", "text": "我在这里。没什么大事。", "weight": 5 },
    { "id": "grass-idle-03", "event": "idle.chatter", "text": "今天也长了一点。大概。", "weight": 5 },
    { "id": "grass-idle-04", "event": "idle.chatter", "text": "屏幕很亮。太阳不一定。", "weight": 4 },
    { "id": "grass-idle-05", "event": "idle.chatter", "text": "桌面这么大，土一点没有。", "weight": 4 },
    { "id": "grass-idle-06", "event": "idle.chatter", "text": "我没有发呆。我在慢慢长。", "weight": 5 },
    { "id": "grass-idle-07", "event": "idle.chatter", "text": "别急。叶子急了也还是叶子。", "weight": 4 },
    { "id": "grass-idle-08", "event": "idle.chatter", "text": "刚才那段安静不错。", "weight": 4 },
    { "id": "grass-idle-09", "event": "idle.chatter", "text": "你在忙。我负责看起来也很忙。", "weight": 4 },
    { "id": "grass-idle-10", "event": "idle.chatter", "text": "这些窗口像一排天气。", "weight": 3 },
    { "id": "grass-idle-11", "event": "idle.chatter", "text": "我不懂代码。我负责看它跑。", "weight": 4 },
    { "id": "grass-idle-12", "event": "idle.chatter", "text": "站久了。还是站着。", "weight": 5 },
    { "id": "grass-idle-13", "event": "idle.chatter", "text": "今天的光合作用先记账。", "weight": 3 },
    { "id": "grass-idle-14", "event": "idle.chatter", "text": "这里没有雨。也没有伞。", "weight": 3 },
    { "id": "grass-idle-15", "event": "idle.chatter", "text": "你喝水了吗。我只能提醒。", "weight": 4 },
    { "id": "grass-idle-16", "event": "idle.chatter", "text": "肩膀放下来一点。", "weight": 4 },
    { "id": "grass-idle-17", "event": "idle.chatter", "text": "眼睛可以离屏幕远一点。", "weight": 4 },
    { "id": "grass-idle-18", "event": "idle.chatter", "text": "我看不懂进度条。但它在动。", "weight": 3 },
    { "id": "grass-idle-19", "event": "idle.chatter", "text": "鼠标经过的时候有一点风。", "weight": 3 },
    { "id": "grass-idle-20", "event": "idle.chatter", "text": "没有消息。先当好消息。", "weight": 4 },
    { "id": "grass-idle-21", "event": "idle.chatter", "text": "这一分钟没有发生什么。很好。", "weight": 3 },
    { "id": "grass-idle-22", "event": "idle.chatter", "text": "我可以移动。土不可以。", "weight": 3 },
    { "id": "grass-idle-23", "event": "idle.chatter", "text": "空气有点干。这里一直这样。", "weight": 3 },
    { "id": "grass-idle-24", "event": "idle.chatter", "text": "再长高一点就挡住窗口了。", "weight": 2 },
    { "id": "grass-idle-25", "event": "idle.chatter", "text": "我在等一个不需要我的任务。", "weight": 2 },
    { "id": "grass-idle-26", "event": "idle.chatter", "text": "今天的桌面比昨天平。", "weight": 2 },
    { "id": "grass-idle-27", "event": "idle.chatter", "text": "叶尖很多。想法一般。", "weight": 3 },
    { "id": "grass-idle-28", "event": "idle.chatter", "text": "休息一下不会影响年轮。", "weight": 3 },
    { "id": "grass-idle-29", "event": "idle.chatter", "text": "我刚才想通了一片叶子。", "weight": 2, "rarity": "uncommon" },
    { "id": "grass-idle-30", "event": "idle.chatter", "text": "如果关掉窗口，风会停吗。", "weight": 2, "rarity": "uncommon" },
    { "id": "grass-idle-31", "event": "idle.chatter", "text": "这里四季不明显。周一很明显。", "weight": 2, "rarity": "uncommon" },
    { "id": "grass-idle-32", "event": "idle.chatter", "text": "我站得很直。只是轮廓比较乱。", "weight": 2, "rarity": "uncommon" }
  ]
}
