    { "id": "grass-session-02", "event": "idle.longSession", "text": "陪了半天，我叶子都干了。", "weight": 5 },
    { "id": "grass-session-03", "event": "idle.longSession", "text": "喝点水吧。草也要浇。", "weight": 4 },
