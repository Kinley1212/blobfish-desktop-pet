{
  "category": "original-idle",
  "phrases": [
    { "id": "original-idle-01", "event": "idle.chatter", "text": "肚子餓了...", "weight": 1 },
    { "id": "original-idle-02", "event": "idle.chatter", "text": "今天天氣不錯", "weight": 1 },
    { "id": "original-idle-03", "event": "idle.chatter", "text": "要不要休息一下", "weight": 1 },
    { "id": "original-idle-04", "event": "idle.chatter", "text": "游泳好累喔", "weight": 1 },
    { "id": "original-idle-05", "event": "idle.chatter", "text": "主人在忙什麼呢", "weight": 1 },
    { "id": "original-idle-06", "event": "idle.chatter", "text": "想睡覺了", "weight": 1 },
    { "id": "original-idle-07", "event": "idle.chatter", "text": "水滴魚也是有尊嚴的", "weight": 1 },
    { "id": "original-idle-08", "event": "idle.chatter", "text": "別再甩我了啦", "weight": 1 },
    { "id": "original-idle-09", "event": "idle.chatter", "text": "今天也要加油喔", "weight": 1 },
    { "id": "original-idle-10", "event": "idle.chatter", "text": "發呆中", "weight": 1 },
    { "id": "original-idle-11", "event": "idle.chatter", "text": "有沒有人可以陪我聊天", "weight": 1 },
    { "id": "original-idle-12", "event": "idle.chatter", "text": "我是水滴魚,不是普通的魚", "weight": 1 },
    { "id": "original-idle-13", "event": "idle.chatter", "text": "泡泡都被我吐光了", "weight": 1 },
    { "id": "original-idle-14", "event": "idle.chatter", "text": "深海的家好想念", "weight": 1 },
    { "id": "original-idle-15", "event": "idle.chatter", "text": "主人今天喝水了嗎", "weight": 1 },
    { "id": "original-idle-16", "event": "idle.chatter", "text": "電腦螢幕好亮喔", "weight": 1 },
    { "id": "original-idle-17", "event": "idle.chatter", "text": "我也想要放假", "weight": 1 },
    { "id": "original-idle-18", "event": "idle.chatter", "text": "鰭有點痠", "weight": 1 },
    { "id": "original-idle-19", "event": "idle.chatter", "text": "誰把我丟到這裡的", "weight": 1 },
    { "id": "original-idle-20", "event": "idle.chatter", "text": "其實我很可愛的", "weight": 1 },
    { "id": "original-idle-21", "event": "idle.chatter", "text": "嘟嘟嘟", "weight": 1 },
    { "id": "original-idle-22", "event": "idle.chatter", "text": "眼睛好像有點花", "weight": 1 },
    { "id": "original-idle-23", "event": "idle.chatter", "text": "該不會忘記我了吧", "weight": 1 },
    { "id": "original-idle-24", "event": "idle.chatter", "text": "游來游去也是一種運動", "weight": 1 },
    { "id": "original-idle-25", "event": "idle.chatter", "text": "心情不錯", "weight": 1 },
    { "id": "original-idle-26", "event": "idle.chatter", "text": "今天心情普通", "weight": 1 },
    { "id": "original-idle-27", "event": "idle.chatter", "text": "想吃點什麼呢", "weight": 1 },
    { "id": "original-idle-28", "event": "idle.chatter", "text": "主人辛苦了", "weight": 1 },
    { "id": "original-idle-29", "event": "idle.chatter", "text": "我在想事情", "weight": 1 },
    { "id": "original-idle-30", "event": "idle.chatter", "text": "別小看水滴魚", "weight": 1 },
    { "id": "original-idle-31", "event": "idle.chatter", "text": "喘口氣", "weight": 1 },
    { "id": "original-idle-32", "event": "idle.chatter", "text": "今天的雲很好看(如果我看得到的話)", "weight": 1 },
    { "id": "original-idle-33", "event": "idle.chatter", "text": "滑鼠不要靠近我", "weight": 1 },
    { "id": "original-idle-34", "event": "idle.chatter", "text": "我在思考鹹魚的意義", "weight": 1 }
  ]
}
