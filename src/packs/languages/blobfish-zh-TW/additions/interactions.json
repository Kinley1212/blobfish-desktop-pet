{
  "category": "interaction",
  "phrases": [
    { "id": "menu-open-01", "event": "interaction.menuOpen", "text": "你要改什么……", "weight": 5 },
    { "id": "menu-open-02", "event": "interaction.menuOpen", "text": "选吧，我等着。", "weight": 4 },
    { "id": "menu-open-03", "event": "interaction.menuOpen", "text": "我先停一下。", "weight": 3 },
    { "id": "menu-open-rare-01", "event": "interaction.menuOpen", "text": "设置里应该没有海水。", "weight": 1, "rarity": "rare" },
    { "id": "paused-01", "event": "interaction.paused", "text": "那我不动了。", "weight": 5 },
    { "id": "paused-02", "event": "interaction.paused", "text": "好吧。停在这里。", "weight": 3 },
    { "id": "paused-03", "event": "interaction.paused", "text": "反正也游不远。", "weight": 2 },
    { "id": "resumed-01", "event": "interaction.resumed", "text": "好吧，继续游。", "weight": 5 },
    { "id": "resumed-02", "event": "interaction.resumed", "text": "又要动了……", "weight": 4 },
    { "id": "resumed-03", "event": "interaction.resumed", "text": "我还以为能歇久一点。", "weight": 2 },
    { "id": "idle-roam-off-01", "event": "interaction.idleRoamOff", "text": "忙完我就停。", "weight": 5 },
    { "id": "idle-roam-off-02", "event": "interaction.idleRoamOff", "text": "没任务就不游了。", "weight": 4 },
    { "id": "idle-roam-off-03", "event": "interaction.idleRoamOff", "text": "好吧。空下来就歇着。", "weight": 3 },
    { "id": "idle-roam-on-01", "event": "interaction.idleRoamOn", "text": "没事也游两下。", "weight": 5 },
    { "id": "idle-roam-on-02", "event": "interaction.idleRoamOn", "text": "好吧，继续晃悠。", "weight": 4 },
    { "id": "idle-roam-on-03", "event": "interaction.idleRoamOn", "text": "空着也是空着……", "weight": 3 },
    { "id": "petting-01", "event": "interaction.petting", "text": "……嗯，勉强让你摸一下。", "weight": 5 },
    { "id": "petting-02", "event": "interaction.petting", "text": "唔……再懒一点点……", "weight": 5 },
    { "id": "petting-03", "event": "interaction.petting", "text": "手感不错吧，天然的。", "weight": 5 },
    { "id": "petting-04", "event": "interaction.petting", "text": "别误会，我只是没力气躲。", "weight": 4 },
    { "id": "petting-05", "event": "interaction.petting", "text": "深海躺平冠军，了解一下。", "weight": 4 },
    { "id": "petting-06", "event": "interaction.petting", "text": "……嗯。就这样，别太用力。", "weight": 4 },
    { "id": "petting-07", "event": "interaction.petting", "text": "摸到的可是限量款。", "weight": 4 },
    { "id": "petting-08", "event": "interaction.petting", "text": "哼，又不是很舒服。", "weight": 3 },
    { "id": "petting-09", "event": "interaction.petting", "text": "再摸下去要起球了。", "weight": 3 },
    { "id": "petting-10", "event": "interaction.petting", "text": "这一身软，别处可找不到。", "weight": 3 },
    { "id": "petting-11", "event": "interaction.petting", "text": "随你吧……我又懒得动。", "weight": 3 },
    { "id": "petting-rare-01", "event": "interaction.petting", "text": "别以为这样我就高兴了……（尾巴悄悄摇）", "weight": 1, "rarity": "rare" },
    { "id": "petting-rare-02", "event": "interaction.petting", "text": "免费仅此一次。……才怪，随时欢迎。", "weight": 1, "rarity": "rare" },
    { "id": "petting-more-01", "event": "interaction.pettingMore", "text": "……还摸。行吧。", "weight": 5 },
    { "id": "petting-more-02", "event": "interaction.pettingMore", "text": "我不躲了，省点力气。", "weight": 5 },
    { "id": "petting-more-03", "event": "interaction.pettingMore", "text": "手感这么好，你也不亏。", "weight": 4 },
    { "id": "petting-more-04", "event": "interaction.pettingMore", "text": "深海也没这种待遇。", "weight": 4 },
    { "id": "petting-more-05", "event": "interaction.pettingMore", "text": "唔……再懒亿点点。", "weight": 4 },
    { "id": "petting-more-06", "event": "interaction.pettingMore", "text": "这不算舒服。只是懒得反驳。", "weight": 3 },
    { "id": "petting-lots-01", "event": "interaction.pettingLots", "text": "随便你了。我不动了。", "weight": 5 },
    { "id": "petting-lots-02", "event": "interaction.pettingLots", "text": "再摸就要塌了。", "weight": 5 },
    { "id": "petting-lots-03", "event": "interaction.pettingLots", "text": "行，你赢了。我承认。", "weight": 4 },
    { "id": "petting-lots-04", "event": "interaction.pettingLots", "text": "限量款被你摸出包浆了。", "weight": 4 },
    { "id": "petting-lots-05", "event": "interaction.pettingLots", "text": "咕噜……已下线。", "weight": 4 },
    { "id": "petting-lots-06", "event": "interaction.pettingLots", "text": "我这辈子最努力的一次，是躺着。", "weight": 3 },
    { "id": "petting-lots-rare-01", "event": "interaction.pettingLots", "text": "水滴魚已融化。请稍后再试。", "weight": 1, "rarity": "rare" }
  ]
}
